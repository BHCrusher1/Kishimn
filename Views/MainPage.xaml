<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Kishimn.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="0,12" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,0" Spacing="6">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="変換元ファイル" />
                <TextBox x:Name="InputPathTextBox" Grid.Column="1" PlaceholderText="入力ファイルを選択" TextChanged="OnAnySettingChanged" />
                <Button Grid.Column="2" Content="参照" Click="OnBrowseInputClick" />
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="保存先ファイル" />
                <TextBox x:Name="OutputPathTextBox" Grid.Column="1" PlaceholderText="出力ファイルを選択" TextChanged="OnAnySettingChanged" />
                <Button Grid.Column="2" Content="参照" Click="OnBrowseOutputClick" />
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="コンテナ" />
                <ComboBox x:Name="ContainerComboBox" Grid.Column="1" MinWidth="120" SelectionChanged="OnContainerChanged" />

                <StackPanel x:Name="Mp4OptionsPanel" Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <CheckBox x:Name="FastStartCheckBox" VerticalAlignment="Center" Content="Web用に最適化" Checked="OnAnySettingChanged" Unchecked="OnAnySettingChanged" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="16,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="動画" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="エンコーダー" />
                        <ComboBox x:Name="VideoEncoderComboBox" Grid.Column="1" MinWidth="240" SelectionChanged="OnVideoEncoderChanged" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="フレームレート" />
                        <ComboBox x:Name="FrameRateComboBox" Grid.Column="1" MinWidth="240" SelectionChanged="OnAnySettingChanged" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="レート指定" />
                        <RadioButtons x:Name="RateModeRadioButtons" Grid.Column="1" MaxColumns="2" SelectionChanged="OnRateModeChanged" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="品質設定" />
                        <StackPanel Grid.Column="1" Spacing="0">
                            <StackPanel x:Name="QualitySliderPanel" Grid.Column="0">
                                <TextBlock x:Name="QualityValueTextBlock" />
                                <Slider x:Name="QualitySlider" SmallChange="1" StepFrequency="1" TickFrequency="1" TickPlacement="BottomRight" ValueChanged="OnQualitySettingChanged" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="QualityMinLabelTextBlock" Grid.Column="0" TextAlignment="Left" />
                                    <TextBlock x:Name="QualityMaxLabelTextBlock" Grid.Column="1" TextAlignment="Right" />
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="BitratePanel" Grid.Column="0" Orientation="Horizontal" Spacing="12" Visibility="Collapsed">
                                <TextBox x:Name="BitrateTextBox" Width="120" InputScope="Number" TextChanged="OnAnySettingChanged" />
                                <TextBlock VerticalAlignment="Center" Text="kbps" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="音声" />
                    <Grid ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="音声オプション" />
                        <RadioButtons x:Name="AudioOptionRadioButtons" Grid.Column="1" MaxColumns="4" SelectionChanged="OnAnySettingChanged" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Padding="16,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="FFmpeg コマンドライン" />
                <TextBox x:Name="CommandLineTextBox" MinHeight="80" IsReadOnly="True" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="6">
                <Button Width="120" Content="リセット" Click="OnResetClick" />
                <Button Width="120" Content="実行" Style="{StaticResource PrimaryAction}" Click="OnExecuteClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
